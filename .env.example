PORT=5000
NODE_ENV=development
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

# Demo login is opt-in. Keep disabled in deployments where public demo access
# is not intended, especially because the admin demo receives admin privileges.
DEMO_LOGIN_ENABLED=false
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=

# Google Gemini Developer API (server-side only)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Google OAuth 2.0 Web Application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
